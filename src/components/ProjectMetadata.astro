---
interface Props {
  role: string;
  timeline: string;
  team: string;
  skills: string[];
}

const { role, timeline, team, skills } = Astro.props;
---

<div class="flex flex-col md:flex-row gap-6 md:gap-12">
  <div class="flex w-full flex-col gap-2">
    <h4 class="!opacity-100">Role</h4>
    <p>{role}</p>
  </div>
  <div class="flex w-full flex-col gap-2">
    <h4 class="!opacity-100">Timeline</h4>
    <p>{timeline}</p>
  </div>
  <div class="flex w-full flex-col gap-2">
    <h4 class="!opacity-100">Team</h4>
    <p>{team}</p>
  </div>
  <div class="flex w-full flex-col gap-2">
    <h4 class="!opacity-100">Skills</h4>
    <div class="flex flex-col gap-0">
      {skills.map((skill) => <p>{skill}</p>)}
    </div>
  </div>
</div>
