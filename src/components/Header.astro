---
import NavLink from './NavLink.astro';
import { resumeUrl } from '../data/config';

const pathname = Astro.url.pathname;
const isWork = pathname === '/';
const isFun = pathname === '/fun';
const isAbout = pathname === '/about';
---

<!-- Desktop + mobile nav -->
<div
  id="site-header"
  class="flex justify-center px-6 py-5 z-50 bg-background gap-6 border-b border-foreground/10 lg:h-16 align-center items-center relative min-h-[32px]"
  style="opacity:0"
>
  <div class="max-w-[1800px] w-full flex items-center gap-6 relative">
    <!-- Logo -->
    <div class="flex items-center w-full">
      <a class="flex flex-col sm:flex-row sm:inline-flex sm:gap-4 gap-0 cursor-pointer !opacity-100" href="/">
        <h4 class="!opacity-100 !text-foreground !font-medium">Tatiana Hernandez</h4>
        <h4 class="flex items-center gap-0">Product Designer + Vibecoder</h4>
      </a>
    </div>

    <!-- Desktop nav -->
    <div class="md:flex hidden gap-2 w-full justify-end items-center">
      <div class="flex gap-1 items-center">
        <NavLink href="/" label="Work" isActive={isWork} />
        <NavLink href="/fun" label="Fun" isActive={isFun} />
        <NavLink href="/about" label="About" isActive={isAbout} />
        <NavLink href={resumeUrl} label="Resume" external />
      </div>

      <!-- TatianaLLM button (desktop) -->
      <div class="flex gap-2 lg:w-full justify-end items-center">
        <button
          id="chat-open-btn"
          class="group flex align-center items-center hover:opacity-100 hover:text-primary transition-all duration-200 rounded-full p-2 h-8 mr-[-8px] w-auto opacity-50"
          aria-label="Open AI chat"
        >
          <svg width="16" height="16" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14.5231 29.2759C12.6685 22.5706 7.42938 17.3315 0.724097 15.4769C0.240255 15.3431 0.240255 14.657 0.724097 14.5231C7.42938 12.6685 12.6685 7.42939 14.5231 0.724099C14.6569 0.240257 15.343 0.240257 15.4769 0.724099C17.3315 7.42939 22.5706 12.6685 29.2759 14.5231C29.7597 14.657 29.7597 15.343 29.2759 15.4769C22.5706 17.3315 17.3315 22.5706 15.4769 29.2759C15.343 29.7597 14.657 29.7597 14.5231 29.2759Z" fill="currentColor" class="group-hover:fill-primary transition-colors duration-200"></path>
          </svg>
          <div class="text-[15px] overflow-hidden transition-all whitespace-nowrap text-current font-mono uppercase font-regular pl-2.5 max-w-[100px] opacity-100">TatianaLLM</div>
        </button>
      </div>
    </div>

    <!-- Hamburger (mobile) -->
    <div class="md:hidden flex gap-4 items-center">
      <button id="hamburger-btn" aria-label="Toggle menu">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" class="cursor-pointer hover:opacity-50">
          <path id="hamburger-top" class="transition-all duration-300 origin-center" d="M4 8H20" stroke="currentColor" stroke-width="2"></path>
          <path id="hamburger-bottom" class="transition-all duration-300 origin-center" d="M4 16H20" stroke="currentColor" stroke-width="2"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="md:hidden absolute left-0 right-0 z-60 top-full p-6 border-b border-foreground/10 bg-background transition-all duration-300 ease-in-out opacity-0 -translate-y-2 pointer-events-none"
  >
    <div class="flex flex-col gap-1">
      <NavLink href="/" label="Work" isActive={isWork} />
      <NavLink href="/fun" label="Fun" isActive={isFun} />
      <NavLink href="/about" label="About" isActive={isAbout} />
      <NavLink href={resumeUrl} label="Resume" external />
    </div>
  </div>

  <!-- TatianaLLM FAB (mobile) -->
  <button
    id="chat-open-btn-mobile"
    class="md:hidden fixed bottom-6 right-6 z-[60] flex items-center justify-center hover:text-primary active:scale-95 transition-all duration-200 rounded-full shadow-lg bg-primary w-12 h-12 opacity-100"
    style="bottom:max(1.5rem, env(safe-area-inset-bottom, 1.5rem));right:max(1.5rem, env(safe-area-inset-right, 1.5rem))"
    aria-label="Open AI chat"
  >
    <svg width="20" height="20" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M14.5231 29.2759C12.6685 22.5706 7.42938 17.3315 0.724097 15.4769C0.240255 15.3431 0.240255 14.657 0.724097 14.5231C7.42938 12.6685 12.6685 7.42939 14.5231 0.724099C14.6569 0.240257 15.343 0.240257 15.4769 0.724099C17.3315 7.42939 22.5706 12.6685 29.2759 14.5231C29.7597 14.657 29.7597 15.343 29.2759 15.4769C22.5706 17.3315 17.3315 22.5706 15.4769 29.2759C15.343 29.7597 14.657 29.7597 14.5231 29.2759Z" fill="#FFFFFF"></path>
    </svg>
  </button>
</div>

<script>
  import { initHeader } from '../scripts/header';

  initHeader();
</script>
