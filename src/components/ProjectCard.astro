---
import type { ProjectStatus } from '../data/projects';
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  title: string;
  label: string;
  href: string;
  aspect?: string;
  placeholderColor?: string;
  video?: string;
  image?: string;
  overlayText?: string;
  external?: boolean;
  cursorType?: string;
  status?: ProjectStatus;
}

const {
  title,
  label,
  href,
  aspect = 'aspect-[16/9]',
  placeholderColor = '#E98D3450',
  video,
  image,
  overlayText,
  external = false,
  cursorType = 'case-study',
  status = 'published',
} = Astro.props;

const isComingSoon = status === 'coming-soon';
const resolvedCursorType = isComingSoon ? 'coming-soon' : cursorType;
---

<a
  class="group block transition-all duration-300 ease-in-out !opacity-100"
  data-cursor={resolvedCursorType}
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  <div class="flex flex-col gap-2">
    <!-- Thumbnail -->
    <div class={`relative w-full ${aspect} border-1 border-foreground/10 overflow-hidden box-border transition-all duration-300 ease-in-out`}>
      <div class="relative w-full h-full overflow-hidden" role="img" aria-label={`Project thumbnail for ${title}`}>
        {video ? (
          <video
            class="absolute inset-0 w-full h-full object-cover"
            src={video}
            autoplay
            loop
            muted
            playsinline
          />
        ) : image ? (
          <img
            class="absolute inset-0 w-full h-full object-cover"
            src={image}
            alt={`Project thumbnail for ${title}`}
          />
        ) : (
          <ImagePlaceholder color={placeholderColor} />
        )}
      </div>
      {overlayText && (
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-10">
          <span class="text-center font-semibold text-xl md:text-2xl leading-tight tracking-tight px-4 text-white/90">
            {overlayText}
          </span>
        </div>
      )}
      {isComingSoon && <span class="project-card__status">Coming Soon</span>}
      <div class="absolute inset-0 bg-background/0 transition-colors duration-300 ease-in-out group-hover:bg-background/40"></div>
    </div>

    <!-- Caption -->
    <div class="flex flex-col justify-between gap-0.5 mt-1 transition-colors duration-300 ease-in-out lg:flex-row">
      <h3 class="project-card__title !text-[17px] overflow-hidden !text-foreground">{title}</h3>
      <h4 class="project-card__label transition-colors duration-300 ease-in-out !text-[15px] overflow-hidden">{label}</h4>
    </div>
  </div>
</a>
