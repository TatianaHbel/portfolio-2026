---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  sections?: string[];
}

const { title, description, sections = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen px-6">
    <main class="grid max-w-[1800px] mx-auto grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-0 md:gap-8">

      <!-- Sidebar -->
      <aside class="md:sticky md:top-0 md:h-fit px-0 pt-12 pb-0 md:py-12 min-w-40">
        <a data-cursor="pointer" class="w-full text-left !opacity-100" href="/">
          <h4 class="hover:!text-primary !opacity-100 hover:cursor-pointer">
            <div class="flex items-center gap-2 hover:!opacity-100 group">
              <svg
                class="w-[18px] h-[18px] flex-shrink-0 fill-current transition-colors duration-200"
                focusable="false"
                aria-hidden="true"
                viewBox="0 0 24 24"
              >
                <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20z"></path>
              </svg>
              Back
            </div>
          </h4>
        </a>

        {sections.length > 0 && (
          <nav id="project-sidebar-nav" class="mt-8 hidden md:block">
            <div class="flex flex-col items-start gap-2">
              {sections.map((section) => (
                <button
                  data-section={section}
                  class="section-nav-btn flex items-start transition-colors cursor-pointer text-left hover:text-foreground opacity-50"
                >
                  {section}
                </button>
              ))}
            </div>
          </nav>
        )}
      </aside>

      <!-- Main content column -->
      <div class="w-fill md:max-w-3xl lg:max-w-4xl py-12 flex flex-col gap-12 md:gap-24">
        <slot />
      </div>

      <!-- Right spacer -->
      <div class="p-6 py-12"></div>

    </main>
  </div>

  <script>
    // Sidebar scroll-spy: highlight the active section
    const navBtns = document.querySelectorAll<HTMLButtonElement>('.section-nav-btn');

    function scrollToSection(sectionId: string) {
      const el = document.getElementById(sectionId)
        ?? document.querySelector(`[id="${sectionId.toLowerCase()}"]`)
        ?? document.querySelector(`section[id*="${sectionId.toLowerCase().split(' ')[0]}"]`);
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    navBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const section = btn.getAttribute('data-section');
        if (section) scrollToSection(section);
      });
    });

    // Scroll-spy: mark active section
    const sections = document.querySelectorAll<HTMLElement>('section[id]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navBtns.forEach((btn) => {
              const match = btn.getAttribute('data-section')?.toLowerCase() === id.toLowerCase()
                || id.toLowerCase().includes(btn.getAttribute('data-section')?.toLowerCase().split(' ')[0] ?? '');
              btn.classList.toggle('opacity-100', match);
              btn.classList.toggle('!text-foreground', match);
              btn.classList.toggle('opacity-50', !match);
            });
          }
        });
      },
      { rootMargin: '-20% 0px -60% 0px' }
    );

    sections.forEach((s) => observer.observe(s));
  </script>
</BaseLayout>
