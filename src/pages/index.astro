---
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeProjectColumns } from '../data/projects';
import { experienceTimeline } from '../data/timeline';

const { left: leftProjects, right: rightProjects } = homeProjectColumns;
---

<BaseLayout title="Tatiana Hernandez | Product Designer + Engineer">
  <div class="flex flex-col p-6 w-full items-center gap-12 font-geist-sans">
    <main class="flex flex-col w-full max-w-[1800px]">
      <div class="w-full">
        <!-- Hero -->
        <div class="grid grid-cols-1 gap-12 lg:gap-6 lg:pt-[26vh] pt-8 pb-8 w-full lg:grid-cols-2">
          <div class="flex flex-col w-full gap-4">
            <h1 class="max-w-[700px]">I'm Tatiana, a product designer who <span class="italic">vibecodes</span>.</h1>
          </div>

          <!-- Experience timeline -->
          <div class="flex flex-col gap-3 w-full align-bottom justify-end">
            <div class="flex flex-col gap-2 lg:gap-[2px]">
              {experienceTimeline.map((entry) => (
                <div class="flex gap-2">
                  <h4 class="w-26 min-w-26">{entry.year}</h4>
                  <div class="flex flex-col lg:flex-row gap-0.5">
                    <div class="w-56 min-w-56">
                      {entry.companyUrl ? (
                        <a href={entry.companyUrl} target="_blank" rel="noopener noreferrer">{entry.company}</a>
                      ) : (
                        <span>{entry.company}</span>
                      )}
                    </div>
                    <p>{entry.role}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Project grid -->
        <div class="grid grid-cols-1 gap-6 transition-all duration-300 ease-in-out lg:grid-cols-2">
          <!-- Left column -->
          <div class="flex flex-col gap-6">
            {leftProjects.map((project) => (
              <ProjectCard
                title={project.title}
                label={project.label}
                href={project.href}
                aspect={project.aspect}
                placeholderColor={project.placeholderColor}
                video={project.video}
                image={project.image}
                overlayText={project.overlayText}
                external={project.external}
                cursorType={project.cursorType}
                status={project.status}
                thumbnailScale={project.thumbnailScale}
              />
            ))}
          </div>

          <!-- Right column -->
          <div class="flex flex-col gap-6">
            {rightProjects.map((project) => (
              <ProjectCard
                title={project.title}
                label={project.label}
                href={project.href}
                aspect={project.aspect}
                placeholderColor={project.placeholderColor}
                video={project.video}
                image={project.image}
                overlayText={project.overlayText}
                external={project.external}
                cursorType={project.cursorType}
                status={project.status}
                thumbnailScale={project.thumbnailScale}
              />
            ))}
          </div>
        </div>
      </div>

      <div class="p-6 py-6"></div>
    </main>
  </div>
</BaseLayout>
