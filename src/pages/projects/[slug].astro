---
import type { HomeProjectCardData } from '../../data/projects';
import { homeProjectColumns } from '../../data/projects';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
  project: HomeProjectCardData;
}

const { project } = Astro.props;

export function getStaticPaths() {
  const allProjects = [...homeProjectColumns.left, ...homeProjectColumns.right];

  return allProjects
    .filter((entry) => entry.status === 'coming-soon' && entry.href.startsWith('/projects/'))
    .map((entry) => ({
      params: { slug: entry.href.replace('/projects/', '') },
      props: { project: entry },
    }));
}
---

<BaseLayout
  title={`${project.title} | Coming Soon | Tatiana Hernandez`}
  description={`${project.title} is being prepared and will be published soon.`}
>
  <div class="min-h-screen px-6 py-24 flex items-center justify-center">
    <div class="max-w-2xl text-center flex flex-col gap-4">
      <h4 class="!opacity-100">Coming Soon</h4>
      <h1>{project.title}</h1>
      <p>{project.label}</p>
      <p>This project page is not published yet. This placeholder route exists so navigation stays valid while the final case study is being prepared.</p>
      <div class="flex justify-center pt-4">
        <a data-cursor="pointer" href="/" class="inline-flex items-center px-4 py-2 rounded-full border border-foreground/10 hover:bg-primary/10">
          Back to Work
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
